// ═══════════════════════════════════════════════════════════════════
// ANFITRIO — Firestore Security Rules
// Pega esto en: Firebase Console → Firestore → Reglas
// ═══════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones helper ──────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isLoggedIn() && getUserData().rol == 'admin';
    }

    function belongsToEmpresa(empresaId) {
      return isLoggedIn() && getUserData().empresaId == empresaId;
    }

    function isAdminOfEmpresa(empresaId) {
      return isAdmin() && getUserData().empresaId == empresaId;
    }

    // ── /empresas/{empresaId} ─────────────────────────────────────
    // Solo el admin de la empresa puede leer su empresa.
    // Ninguna empresa puede ver los datos de otra.
    match /empresas/{empresaId} {
      allow read:   if isAdminOfEmpresa(empresaId);
      allow create: if isAdmin();
      allow update: if isAdminOfEmpresa(empresaId);
      allow delete: if isAdminOfEmpresa(empresaId);
    }

    // ── /usuarios/{uid} ───────────────────────────────────────────
    // Cada usuario puede leer y editar su propio perfil.
    // El admin puede ver/editar los usuarios de su empresa.
    // Nadie puede ver usuarios de otras empresas.
    match /usuarios/{uid} {
      allow read:   if isLoggedIn() && (
                      request.auth.uid == uid ||
                      (isAdmin() && getUserData().empresaId == resource.data.empresaId)
                    );
      allow create: if isAdmin();
      allow update: if isLoggedIn() && (
                      request.auth.uid == uid ||
                      isAdminOfEmpresa(resource.data.empresaId)
                    );
      allow delete: if isAdminOfEmpresa(resource.data.empresaId);
    }

    // ── /checkouts/{checkoutId} ───────────────────────────────────
    // Los empleados pueden crear y leer checkouts de su empresa.
    // Solo los admins pueden eliminar.
    // Una empresa NUNCA accede a checkouts de otra.
    match /checkouts/{checkoutId} {
      allow read:   if isLoggedIn() && belongsToEmpresa(resource.data.empresaId);
      allow create: if isLoggedIn() &&
                      request.resource.data.empresaId == getUserData().empresaId;
      allow update: if isLoggedIn() &&
                      resource.data.empresaId == getUserData().empresaId;
      allow delete: if isAdminOfEmpresa(resource.data.empresaId);
    }

    // ── Bloquear todo lo demás ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
